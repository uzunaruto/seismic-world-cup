# =============================================================================
# Seismic World Cup — environment variables
# =============================================================================
# Copy this to .env.local and fill in real values. Never commit .env.local.

# -----------------------------------------------------------------------------
# Discord OAuth (implicit flow — NO client secret needed)
# App ID 1509035141526192299 ("Seismic Card") is already in the Seismic guild
# IMPORTANT: After deploying to a new domain, you MUST manually add the
# redirect URI to https://discord.com/developers/applications/1509035141526192299/oauth2
# (VPS cannot PATCH the redirect URIs programmatically — see discord-oauth-implicit-flow skill)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DISCORD_CLIENT_ID=1509035141526192299
NEXT_PUBLIC_DISCORD_GUILD_ID=1343751435711414362
NEXT_PUBLIC_DISCORD_REDIRECT_URI=http://localhost:3000/

# -----------------------------------------------------------------------------
# Supabase
# Create project at https://supabase.com/dashboard
# Settings → API → Project URL + service_role key
# Run supabase/schema.sql in the SQL editor
# Create a public storage bucket named 'composites'
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only, never expose to client

# -----------------------------------------------------------------------------
# Discord (moderator workflow)
# Server settings → Integrations → Webhooks → new webhook in #curator channel
# https://discord.com/developers/applications → Bot → Token (for reaction listener)
# Enable Developer Mode to copy channel/server IDs
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=
DISCORD_CURATOR_CHANNEL_ID=       # right-click #curator channel → Copy Channel ID
DISCORD_BOT_TOKEN=                # for /bot/index.js (reaction listener)
DISCORD_GUILD_ID=1343751435711414362

# -----------------------------------------------------------------------------
# Replicate (AI face-swap)
# https://replicate.com/account/api-tokens
# Default model: cjwbw/face-swap (~$0.005/run, ~1.5s inference)
# -----------------------------------------------------------------------------
REPLICATE_API_TOKEN=
REPLICATE_FACE_SWAP_MODEL=cjwbw/face-swap

# -----------------------------------------------------------------------------
# Public config
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_SCENE_PATH=/assets/podium-base.png
