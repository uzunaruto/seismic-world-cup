# =============================================================================
# Seismic World Cup — environment variables
# =============================================================================
# Copy to .env.local. Never commit .env.local.

# -----------------------------------------------------------------------------
# Discord OAuth (implicit flow — no client secret needed)
# App 1509035141526192299 is already in the Seismic guild.
# After deploying to a new domain, MANUALLY add the redirect URI to
# https://discord.com/developers/applications/1509035141526192299/oauth2
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DISCORD_CLIENT_ID=1509035141526192299
NEXT_PUBLIC_DISCORD_GUILD_ID=1343751435711414362
NEXT_PUBLIC_DISCORD_REDIRECT_URI=http://localhost:3000/

# -----------------------------------------------------------------------------
# Supabase
# Create at https://supabase.com/dashboard
# Run supabase/schema.sql in SQL editor.
# Create a public storage bucket named 'cards' (Storage → New bucket).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Discord (moderator workflow)
# Webhook: Server settings → Integrations → Webhooks → new in #curator
# Bot token: https://discord.com/developers/applications → Bot
# Enable Developer Mode to copy channel/server IDs
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=
DISCORD_CURATOR_CHANNEL_ID=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=1343751435711414362

# -----------------------------------------------------------------------------
# Public config
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
